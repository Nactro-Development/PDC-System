<UserControl x:Class="PDC_System.Email.EmailWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PDC_System.Email"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F0F2F5"
             Unloaded="UserControl_Unloaded">

    <UserControl.Resources>

        <!-- ── Colors ──────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBrush"     Color="#1A73E8"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1557B0"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush"  Color="#F8F9FA"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#DADCE0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202124"/>
        <SolidColorBrush x:Key="TextSecBrush"     Color="#5F6368"/>
        <SolidColorBrush x:Key="AccentRedBrush"   Color="#D93025"/>
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#137333"/>
        <SolidColorBrush x:Key="UnreadBgBrush"    Color="#E8F0FE"/>

        <!-- ── Base Button ──────────────────────────────────────────── -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding"           Value="16,8"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"   Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAF1FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="{StaticResource AccentRedBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextSecBrush}"/>
            <Setter Property="Padding"     Value="6"/>
            <Setter Property="FontSize"    Value="15"/>
        </Style>

        <!-- ── TextBox ──────────────────────────────────────────────── -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="Background"       Value="White"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl ───────────────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"     Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecBrush}"/>
            <Setter Property="Padding"      Value="20,12"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="PART_Border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid ──────────────────────────────────────────────── -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"         Value="False"/>
            <Setter Property="CanUserAddRows"              Value="False"/>
            <Setter Property="CanUserDeleteRows"           Value="False"/>
            <Setter Property="CanUserReorderColumns"       Value="False"/>
            <Setter Property="GridLinesVisibility"         Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush"    Value="#EEEEEE"/>
            <Setter Property="BorderThickness"             Value="0"/>
            <Setter Property="Background"                  Value="White"/>
            <Setter Property="RowBackground"               Value="White"/>
            <Setter Property="AlternatingRowBackground"    Value="#FAFAFA"/>
            <Setter Property="SelectionMode"               Value="Single"/>
            <Setter Property="HeadersVisibility"           Value="Column"/>
            <Setter Property="FontFamily"                  Value="Segoe UI"/>
            <Setter Property="FontSize"                    Value="13"/>
            <Setter Property="Foreground"                  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="ColumnHeaderHeight"          Value="40"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#F8F9FA"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecBrush}"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="12,0"/>
            <Setter Property="BorderBrush"   Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="44"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F3F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Toolbar button (for rich-text) ───────────────────────── -->
        <Style x:Key="RteBtn" TargetType="ToggleButton">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RtePushBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding"   Value="2"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════ ROOT GRID ═══════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header bar -->
            <RowDefinition Height="Auto"/>  <!-- credential error banner -->
            <RowDefinition Height="*"/>     <!-- main content -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header Bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" >
                    <TextBlock Text="✉" FontSize="20" VerticalAlignment="Center"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Email" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" >
                    <Button Content="✎  Signature"
                            Style="{StaticResource OutlineBtn}"
                            Command="{Binding OpenSignatureEditorCommand}"
                            Padding="12,7"/>
                    <Button Content="↻  Refresh"
                            Style="{StaticResource OutlineBtn}"
                            Command="{Binding RefreshCommand}"
                            Padding="12,7"/>
                    <Button Content="＋  Compose"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding OpenComposeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Credential Error Banner ────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#FFF3CD"
                BorderBrush="#FFEEBA"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding HasCredentialError, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
            <TextBlock Text="⚠  Email credentials not found. Please add PDCEmail and PDCAppPassword in Settings."
                       Foreground="#856404"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ══════════════ MAIN CONTENT ════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- ── Email List + Reader (side-by-side) ─────────────────── -->
            <TabControl x:Name="MainTabs"
                        BorderThickness="0"
                        Background="{StaticResource SurfaceBrush}">

                <!-- ─────────────────── INBOX ─────────────────────────── -->
                <TabItem Header="📥  Inbox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Email list -->
                        <Border Grid.Column="0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,1,0">
                            <DataGrid x:Name="InboxGrid"
                                      ItemsSource="{Binding InboxEmails}"
                                      SelectedItem="{Binding SelectedInboxEmail, Mode=TwoWay}"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="From" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="12,0">
                                                    <TextBlock Text="{Binding FromAddress}"
                                                               FontWeight="{Binding IsRead, Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Subject" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="12,0" >
                                                    <TextBlock Text="{Binding Subject}"
                                                               FontWeight="{Binding IsRead, Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="📎"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Visibility="{Binding HasAttachments, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Date" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DateReceived, StringFormat=\{0:MM/dd HH:mm\}}"
                                                           Foreground="{StaticResource TextSecBrush}"
                                                           FontSize="12"
                                                           Margin="12,0"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1" Width="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- Email reader -->
                        <local:EmailReader Grid.Column="2"
                                           Email="{Binding SelectedInboxEmail}"
                                           DownloadCommand="{Binding DownloadAttachmentCommand}"/>
                    </Grid>
                </TabItem>

                <!-- ─────────────────── SENT ──────────────────────────── -->
                <TabItem Header="📤  Sent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,1,0">
                            <DataGrid x:Name="SentGrid"
                                      ItemsSource="{Binding SentEmails}"
                                      SelectedItem="{Binding SelectedSentEmail, Mode=TwoWay}"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="To" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ToAddress}"
                                                           Margin="12,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Subject" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="12,0" >
                                                    <TextBlock Text="{Binding Subject}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="📎"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasAttachments, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Sent" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DateReceived, StringFormat=\{0:MM/dd HH:mm\}}"
                                                           Foreground="{StaticResource TextSecBrush}"
                                                           FontSize="12"
                                                           Margin="12,0"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <local:EmailReader Grid.Column="2"
                                           Email="{Binding SelectedSentEmail}"
                                           DownloadCommand="{Binding DownloadAttachmentCommand}"/>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- ══════════ COMPOSE OVERLAY ══════════════════════════════ -->
            <Grid Visibility="{Binding IsComposeOpen, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <!-- dimmed backdrop -->
                <Border Background="#88000000"/>

                <!-- compose card -->
                <Border Background="White"
                        CornerRadius="12"
                        Width="680"
                        MaxHeight="680"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Effect="{x:Static local:ShadowHelper.CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- title bar -->
                            <RowDefinition Height="Auto"/>  <!-- to -->
                            <RowDefinition Height="Auto"/>  <!-- subject -->
                            <RowDefinition Height="Auto"/>  <!-- rte toolbar -->
                            <RowDefinition Height="*"/>     <!-- body -->
                            <RowDefinition Height="Auto"/>  <!-- attachments -->
                            <RowDefinition Height="Auto"/>  <!-- action bar -->
                        </Grid.RowDefinitions>

                        <!-- title -->
                        <Border Grid.Row="0"
                                Background="{StaticResource PrimaryBrush}"
                                CornerRadius="12,12,0,0"
                                Padding="20,14">
                            <Grid>
                                <TextBlock Text="New Message"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource BaseBtn}"
                                        Background="Transparent"
                                        Foreground="White"
                                        FontSize="16"
                                        Padding="8,4"
                                        Command="{Binding CloseComposeCommand}"/>
                            </Grid>
                        </Border>

                        <!-- To -->
                        <Grid Grid.Row="1" Margin="20,16,20,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="To" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecBrush}"
                                       FontFamily="Segoe UI" FontSize="13"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ComposeTo, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}"/>
                        </Grid>

                        <!-- Subject -->
                        <Grid Grid.Row="2" Margin="20,8,20,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subject" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecBrush}"
                                       FontFamily="Segoe UI" FontSize="13"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ComposeSubject, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}"/>
                        </Grid>

                        <!-- RTE Toolbar -->
                        <Border Grid.Row="3"
                                Margin="20,10,20,0"
                                Background="#F8F9FA"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8,8,0,0"
                                Padding="6,4">
                            <WrapPanel Orientation="Horizontal" >
                                <!-- Font Family -->
                                <ComboBox x:Name="FontFamilyCombo"
                                          Width="120" Height="26"
                                          FontSize="12"
                                          SelectedIndex="0"
                                          >
                                    <ComboBoxItem Content="Segoe UI"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Times New Roman"/>
                                    <ComboBoxItem Content="Courier New"/>
                                    <ComboBoxItem Content="Georgia"/>
                                    <ComboBoxItem Content="Verdana"/>
                                </ComboBox>
                                <!-- Font Size -->
                                <ComboBox x:Name="FontSizeCombo"
                                          Width="55" Height="26"
                                          FontSize="12"
                                          SelectedIndex="2"
                                         >
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="24"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>
                                <Separator Margin="4,2"/>
                                <ToggleButton x:Name="BoldBtn" Content="B"
                                              Style="{StaticResource RteBtn}"
                                              FontWeight="Bold"
                                              Click="BoldBtn_Click" ToolTip="Bold (Ctrl+B)"/>
                                <ToggleButton x:Name="ItalicBtn" Content="I"
                                              Style="{StaticResource RteBtn}"
                                              FontStyle="Italic"
                                              Click="ItalicBtn_Click" ToolTip="Italic (Ctrl+I)"/>
                                <ToggleButton x:Name="UnderlineBtn"
              Style="{StaticResource RteBtn}"
              Click="UnderlineBtn_Click">
                                    <TextBlock Text="U"
               TextDecorations="Underline"/>
                                </ToggleButton>


                                <Separator Margin="4,2"/>
                                <!-- Text color -->
                                <Button Content="A" Style="{StaticResource RtePushBtn}"
                                        Click="TextColorBtn_Click" ToolTip="Text Color"
                                        x:Name="TextColorBtn"/>
                                <Separator Margin="4,2"/>
                                <!-- Alignment -->
                                <Button Content="≡" Style="{StaticResource RtePushBtn}"
                                        Click="AlignLeftBtn_Click" ToolTip="Align Left"/>
                                <Button Content="☰" Style="{StaticResource RtePushBtn}"
                                        Click="AlignCenterBtn_Click" ToolTip="Center"/>
                                <Button Content="≣" Style="{StaticResource RtePushBtn}"
                                        Click="AlignRightBtn_Click" ToolTip="Align Right"/>
                                <Separator Margin="4,2"/>
                                <!-- Lists -->
                                <Button Content="•≡" Style="{StaticResource RtePushBtn}"
                                        Click="BulletListBtn_Click" ToolTip="Bullet List"/>
                                <Button Content="1≡" Style="{StaticResource RtePushBtn}"
                                        Click="NumberedListBtn_Click" ToolTip="Numbered List"/>
                                <Separator Margin="4,2"/>
                                <!-- Hyperlink -->
                                <Button Content="🔗" Style="{StaticResource RtePushBtn}"
                                        Click="HyperlinkBtn_Click" ToolTip="Insert Hyperlink"/>
                            </WrapPanel>
                        </Border>

                        <!-- Body - RichTextBox -->
                        <RichTextBox x:Name="BodyEditor"
                                     Grid.Row="4"
                                     Margin="20,0,20,0"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1,0,1,1"
                                     Padding="12"
                                     FontFamily="Segoe UI"
                                     FontSize="14"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="160"
                                     SelectionChanged="BodyEditor_SelectionChanged"/>

                        <!-- Attachment bar -->
                        <Border Grid.Row="5"
                                Margin="20,8,20,0"
                                Background="#F8F9FA"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding AttachmentSummary}"
                                           Foreground="{StaticResource TextSecBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="📎 Attach"
                                        Style="{StaticResource OutlineBtn}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Command="{Binding AddAttachmentCommand}"
                                        Margin="0,0,6,0"/>
                                <Button Grid.Column="2"
                                        Content="✕ Clear"
                                        Style="{StaticResource OutlineBtn}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Command="{Binding ClearAttachmentsCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Action bar -->
                        <Border Grid.Row="6"
                                Padding="20,12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{StaticResource TextSecBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"
                                           MaxWidth="300"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            >
                                    <Button Content="Discard"
                                            Style="{StaticResource OutlineBtn}"
                                            Command="{Binding CloseComposeCommand}"/>
                                    <Button Content="✈  Send"
                                            Style="{StaticResource PrimaryBtn}"
                                            Command="{Binding SendEmailCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={x:Static local:InverseBoolConverter.Instance}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════ SIGNATURE EDITOR OVERLAY ════════════════════ -->
            <Grid Visibility="{Binding IsSignatureEditorOpen, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <Border Background="#88000000"/>
                <Border Background="White"
                        CornerRadius="12"
                        Width="560"
                        MaxHeight="480"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Effect="{x:Static local:ShadowHelper.CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource PrimaryBrush}"
                                CornerRadius="12,12,0,0"
                                Padding="20,14">
                            <TextBlock Text="Edit Email Signature"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBox Grid.Row="1"
                                 Text="{Binding SignatureHtml, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}"
                                 Margin="20,16,20,8"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="200"
                                 FontFamily="Consolas"
                                 FontSize="12"/>
                        <Border Grid.Row="2"
                                Padding="20,12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        >
                                <Button Content="Cancel"
                                        Style="{StaticResource OutlineBtn}"
                                        Command="{Binding OpenSignatureEditorCommand}">


                                    <Button.CommandParameter>
                                        <sys:Boolean>False</sys:Boolean>
                                    </Button.CommandParameter>
                                </Button>
                                
                                
                                <Button Content="Save Signature"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding SaveSignatureCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

        </Grid>

        <!-- ── Status Bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right"
                             Width="100" Height="4"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
