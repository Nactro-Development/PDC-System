<Window x:Class="PDC_System.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" 
        ResizeMode="CanResize"
        Foreground="{DynamicResource Forground}"
        Background="{DynamicResource Background}"
        WindowStartupLocation="CenterScreen"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        AllowsTransparency="True"
        x:Name="WindowForgrounf"
        Title="PDC Backup Demo" Width="800">

    <!-- Window Chrome to customize window borders and corners -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            CornerRadius="10"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Main container grid -->
    <Grid x:Name="MainGrid">
        <!-- Outer border with drop shadow effect -->
        <Border CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"  x:Name="BorderBackgroud">
           
            <StackPanel Margin="10">
                <Grid>
                    <Border CornerRadius="10" Margin="8">
                        <Grid>

                            <!-- Define 4 rows for layout -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Close button -->
                                <RowDefinition Height="Auto"/>
                                <!-- Profile info -->
                                <RowDefinition Height="Auto"/>
                                <!-- Backup buttons -->
                                <RowDefinition Height="Auto"/>
                                <!-- Drive size and log -->
                            </Grid.RowDefinitions>

                            <!-- Close button in top-right -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Right">
                                <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Width="25" Height="25"
                                        HorizontalAlignment="Center" Content="X" VerticalAlignment="Center" Style="{StaticResource NavigationButtonStyle}" 
                                        Click="btnClose_Click">
                                    
                                </Button>
                            </StackPanel>


                            <!-- Backup and restore buttons section -->
                            <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Backup and Restore" Margin="10" FontSize="24" FontWeight="Bold" TextAlignment="Center" FontFamily="DM Sans 14pt"/>
                                <TextBlock Text="Manage your data with ease and security. Backup, restore." 
                                           TextAlignment="Center" TextWrapping="Wrap" Width="500" Margin="0,10,0,40" FontSize="18" FontWeight="Medium" FontFamily="DM Sans 12pt"/>

                              
                                <!-- Auto-backup settings -->
                                <Border Width="500"  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" Padding="10" Margin="0,0,0,15" CornerRadius="6" Background="{DynamicResource Background}">
                                    <StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8" >
                                            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Forground}" Text="Enable Auto Backup" />
                                            <CheckBox x:Name="chkAutoBackup" Content="Enable Auto Backup"  FontSize="14" Margin="4.6,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                            <TextBlock Text="Interval (minutes):" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                                            <TextBox x:Name="txtAutoBackupInterval" Width="100" Style="{StaticResource TextBoxStyle}" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <Button x:Name="btnSaveAutoBackupSettings" Width="150" Height="36" Click="SaveAutoBackupSettings_Click" Style="{StaticResource BackuoStyle}">
                                            <TextBlock Text="Save Settings" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Custom Save Location Section -->
                                <TextBlock Text="Custom Backup Location" FontSize="14" FontWeight="SemiBold" 
             FontFamily="DM Sans 12pt" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                <Grid Width="500" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtCustomBackupPath" Grid.Column="0" 
               IsReadOnly="True" Height="36"
               Style="{StaticResource TextBoxStyle}"
               VerticalContentAlignment="Center"
               Text="No custom location set"/>
                                    <Button Grid.Column="1" Width="100" Height="36" Margin="8,0,0,0"
              Click="BrowseBackupLocation_Click"
              Style="{StaticResource BackuoStyle}"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Browse" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>


                                <Button Width="300" Height="40" Click="SaveAndBackup_Click" Style="{StaticResource BackuoStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Asse_9.png" Width="20" Height="20" HorizontalAlignment="Center"/>
                                        <TextBlock Margin="10,0,0,0" Text="Backup" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <Button Width="150" Height="40" Content="Restore" Click="Restore_Click" Margin="10" Style="{StaticResource NavigationButtonStyle}"/>
                                    <Button Width="40" Height="40" Click="CustomRestore_Click" Content="📄︎" FontSize="15" Margin="10" Style="{StaticResource NavigationButtonStyle}">
                                    
                                    </Button>
                                </StackPanel>

                            </StackPanel>

                            <!-- Drive size info and log view -->
                            <StackPanel Grid.Row="3" Width="600">
                                <!-- Log label -->
                                <TextBlock Text="Backup Log View" Margin="10,5,0,0" FontSize="20" FontWeight="Bold" FontFamily="DM Sans 14pt"/>

                                <!-- Log display textbox -->
                                <TextBox x:Name="txtHistory" 
                                         HorizontalAlignment="Stretch" 
                                         VerticalAlignment="Bottom"
                                         Height="150"
                                         Margin="10"
                                         Style="{StaticResource TextBoxStyle}" 
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Hidden"/>
                            </StackPanel>

                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>