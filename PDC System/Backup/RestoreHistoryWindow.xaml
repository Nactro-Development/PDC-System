<Window x:Class="PDC_System.Backup.RestoreHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Foreground="{DynamicResource Forground}"
        Background="{DynamicResource Background}"
        Width="540" Height="480"
        Title="Restore Backup">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" CornerRadius="12"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2">
        <Grid Margin="18,14,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Restore Backup" FontSize="20" FontWeight="Bold"
                               FontFamily="DM Sans 14pt"/>
                    <TextBlock Text="Select a backup from the list below to restore."
                               FontSize="13" Opacity="0.65" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="26" Height="26" Content="✕"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{StaticResource NavigationButtonStyle}"
                        Click="btnClose_Click"/>
            </Grid>

            <!-- Column Headers -->
            <Grid Grid.Row="1" Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="File Name" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Column="1" Text="Date &amp; Time" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" FontSize="12" Opacity="0.7" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Backup List -->
            <ListBox x:Name="lstBackups" Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource BorderBrush}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="lstBackups_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A0660FE"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#0D0660FE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Latest badge -->
                                <Border Visibility="{Binding IsLatestVisibility}" Background="#0660FE"
                                        CornerRadius="4" Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <TextBlock Text="Latest" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="{Binding FileName}" FontSize="13" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding CreatedDate}" FontSize="12"
                                       VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Grid.Column="2" Text="{Binding FileSize}" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.8"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- No backups message -->
            <TextBlock x:Name="txtNoBackups" Grid.Row="2"
                       Text="No backup files found in the default backup location."
                       FontSize="14" Opacity="0.55"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- Bottom action bar -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtSelectedInfo" Grid.Column="0"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.65"
                           Text="No backup selected." TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="1" x:Name="btnRestore"
                        Content="Restore Selected" Width="140" Height="38"
                        Margin="8,0,0,0" IsEnabled="False"
                        Style="{StaticResource BackuoStyle}"
                        Click="btnRestore_Click"/>

                <Button Grid.Column="2" Content="Cancel" Width="80" Height="38"
                        Margin="8,0,0,0"
                        Style="{StaticResource NavigationButtonStyle}"
                        Click="btnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>