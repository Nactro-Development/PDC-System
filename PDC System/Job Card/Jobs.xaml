<UserControl x:Class="PDC_System.Jobs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDC_System"
             mc:Ignorable="d"
             xmlns:cal="clr-namespace:ModernCalendarLib;assembly=ModernCalendarLib"
             MinWidth="1004" MinHeight="660">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ROW 0: TITLE -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Job Cards" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       Foreground="{DynamicResource Forground}"                        
                       TextAlignment="Left" 
                       Margin="0,0,0,5" />

            <TextBlock Grid.Row="1"
                       Text="• View and manage all job cards." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="2"
                       Text="• Add new job cards using the 'Add Job' button." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="3"
                       Text="• View or delete existing job cards from the action column." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left" />
        </Grid>


        <!-- ROW 1: SEARCH BOX -->
        <Grid Grid.Row="1" Margin="0,10,0,10">

            <StackPanel Orientation="Horizontal" >
                <TextBox HorizontalAlignment="Left"
             Name="NameAutoCompleteBox1"
             ToolTip="Search by Employee Name or ID"
             Height="35"
             Style="{DynamicResource OutsourceSerchBar}"
             Width="300"
             TextChanged="SearchBox_TextChanged2" />

                <Button HorizontalAlignment="Left" Click="Refresh_Click" Content="Refresh" Style="{DynamicResource ActionButton}" Margin="10,0,0,0" />
            </StackPanel>
        
        </Grid>


        <!-- ROW 2: DATE FILTER -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Content="From:"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Forground}"/>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="2"
                    Height="35"
                    CornerRadius="5">
                <cal:CustomDatePicker x:Name="StartDatePicker" Width="250"/>
            </Border>

            <Label Grid.Column="2"
                   Content="To:"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Forground}"/>

            <Border Grid.Column="3"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="2"
                    Height="35"
                    CornerRadius="5">
                <cal:CustomDatePicker x:Name="EndDatePicker" Width="250"/>
            </Border>

            <Button Grid.Column="4"
                    Content="Search"
                    Click="Search_Click"
                    Margin="5"
                    Height="35"
                    Style="{StaticResource ActionButton}" />

            <Button Grid.Column="5"
                    Content="Reset"
                    Click="Reset_Click"
                    Margin="5"
                    Height="35"
                    Style="{StaticResource NavigationButtonStyle}" />
        </Grid>


        <Grid Grid.Row="3" Margin="0,10,0,0">

            <StackPanel Orientation="Horizontal" >
                <ComboBox 
          x:Name="TypeFilterComboBox"
          Width="130"
                     Style="{DynamicResource ComboBoxFlatStyle}"
          Height="35"
          Margin="5"
          SelectionChanged="TypeFilterComboBox_SelectionChanged">

                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="Digital"/>
                    <ComboBoxItem Content="Offset"/>

                </ComboBox>

                <ComboBox 
          x:Name="PlateCompanyComboBox"
          Width="180"
          Height="35"
                    Style="{DynamicResource ComboBoxFlatStyle}"
          Margin="5"
          Visibility="Collapsed"
          SelectionChanged="PlateCompanyComboBox_SelectionChanged"/>
            </StackPanel>

        </Grid>

        <!-- ROW 3: DATA GRID AREA -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar: Add Job + Mini Widget -->
            <Grid Grid.Row="0" Margin="10,10,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="+ Add Job"
                        Click="AddJobCard_Click"
                        Margin="0,0,10,0"
                        Width="150"
                        Height="30"
                        Style="{StaticResource ActionButton}" />

                <CheckBox Grid.Column="1"
                          x:Name="MiniWidgetCheckBox"
                          VerticalAlignment="Center"
                          Checked="MiniWidgetCheckBox_CheckedChanged"
                          Unchecked="MiniWidgetCheckBox_CheckedChanged"/>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="Mini Widget"
                           FontSize="12"
                           Foreground="{DynamicResource Forground}"
                           Margin="5,0,0,0"/>
            </Grid>
            
            
            

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      x:Name="JobCardDataGrid"
                      Margin="10"
                      Background="Transparent"
                      SnapsToDevicePixels="True"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="False"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      Style="{StaticResource DataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      PreviewMouseLeftButtonDown="JobCardDataGrid_PreviewMouseLeftButtonDown">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Seen" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSeen, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, 
                                                       Path=IsSelected, 
                                                       Converter={StaticResource BooleanToVisibilityConverter}}"
                                          LostFocus="CheckBox_LostFocus" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Date"
    Binding="{Binding JobCardDate, StringFormat=yyyy-MM-dd}"
    Width="*"
    ElementStyle="{DynamicResource DataGridColumnsStyle}" />
                    <DataGridTextColumn Header="Customer Name"   Binding="{Binding Customer_Name}"  Width="*" ElementStyle="{DynamicResource DataGridColumnsStyle}" />
                    <DataGridTextColumn Header="Description"     Binding="{Binding Description}"    Width="*" ElementStyle="{DynamicResource DataGridColumnsStyle}" />
                    <DataGridTemplateColumn Header="Type" Width="*">

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Border x:Name="TypeBorder"
                    Padding="10,4"
                    CornerRadius="5"
                                        Height="25"
                    HorizontalAlignment="Center"
                    BorderThickness="1">

                                    <TextBlock Text="{Binding Type}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                                               x:Name="TextJob"
                           VerticalAlignment="Center"/>

                                </Border>

                                <DataTemplate.Triggers>

                                    <!-- Digital -->
                                    <DataTrigger Binding="{Binding Type}" Value="Digital">

                                        <Setter TargetName="TypeBorder"
                            Property="Background"
                            Value="#33FF4A4A"/>
                                        
                                        

                                        <Setter TargetName="TypeBorder"
                            Property="BorderBrush"
                            Value="#FF4A4A"/>


                                        <Setter TargetName="TextJob" Property="Foreground" Value="#FF4A4A" />
                                        
                                    </DataTrigger>

                                    <!-- Offset -->
                                    <DataTrigger Binding="{Binding Type}" Value="Offset">

                                        <Setter TargetName="TypeBorder"
                            Property="Background"
                            Value="#334DA6FF"/>

                                        <Setter TargetName="TypeBorder"
                            Property="BorderBrush"
                            Value="#4DA6FF"/>

                                        <Setter TargetName="TextJob" Property="Foreground" Value="#4DA6FF" />

                                    </DataTrigger>

                                </DataTemplate.Triggers>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>
                    

                    <DataGridTemplateColumn Header="Action" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Margin="3" Content="View"   Style="{DynamicResource ActionButton}"         Click="OpenJobCardButton_Click"/>
                                    <Button Grid.Column="1" Margin="3" Content="Edit"   Style="{DynamicResource EditActionButton}"     Click="EditJob_Click"/>
                                    <Button Grid.Column="2" Margin="3" Content="Delete" Style="{DynamicResource NavigationButtonStyle}" Click="DeleteJob_Click"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

        </Grid>

    </Grid>
</UserControl>
