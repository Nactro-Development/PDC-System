<Window x:Class="PDC_System.Fingerprint"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDC_System"
        mc:Ignorable="d"
        
        WindowStyle="None"
         Background="{DynamicResource ThemeBackground}"
        Title="Fingerprint"  Width="800">
    <Grid>

        <!-- Header -->
        <Border Height="55"
                VerticalAlignment="Top"
                Background="{DynamicResource Background}">

            <Grid Margin="15,0">
                <TextBlock Text="🛡 Security Authentication"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Content="✕"
                        Width="35"
                        Height="35"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"/>
            </Grid>

        </Border>

        <StackPanel Margin="30,80,30,20">

            <!-- Scanner -->
            <Grid Width="220"
                  Height="220"
                  HorizontalAlignment="Center">

                <Ellipse 
                    Stroke="#536384"
                    StrokeThickness="4"
                    StrokeDashArray="3 3"/>

                <Ellipse Margin="20"
                         Fill="#263553"/>

                <Ellipse Margin="35"
                         Fill="#1B2740"
                         Stroke="#4D6BAA"
                         StrokeThickness="2"/>

                <!-- Fingerprint Icon -->
                <Image x:Name="MyGifImage"
Width="70"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
RenderOptions.BitmapScalingMode="HighQuality"
SnapsToDevicePixels="True"/>
                
            </Grid>

            <!-- Status -->

            <Border Margin="0,20"
                    Background="#3C4568"
                    CornerRadius="15"
                    Padding="15,5"
                    HorizontalAlignment="Center" Height="33" Width="178">

                <TextBlock VerticalAlignment="Center" TextAlignment="Center" Text="● AWAITING INPUT"
                           Foreground="#D9E4FF"
                           FontWeight="Bold"/>
            </Border>

            <!-- Title -->

            <TextBlock Text="Biometric ID Required"
                       FontSize="25"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Margin="0,10"
                       TextAlignment="Center"
                       Foreground="#C2C9DA"
                       FontSize="20
                       "
                       FontWeight="SemiBold"
                       Width="404"
                       TextWrapping="Wrap"
                       Text="Please place your finger on the scaanner to authorize access to the SecureGuard Admin Console."/>

            <!-- Info -->

            <Grid Margin="0,35">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="12"
                        Background="#1A233B"
                        Padding="15">

                    <StackPanel>

                        <TextBlock
                            Text="TERMINAL ID"
                            Foreground="#8E9AB9"/>

                        <TextBlock
    x:Name="txtDeviceName"
    Foreground="White"
    FontWeight="Bold"/>

                        <TextBlock
    x:Name="txtModel"
    Foreground="White"
    FontWeight="Bold"/>

                        <TextBlock
    x:Name="txtFirmware"
    Foreground="White"
    FontWeight="Bold"/>

                        <TextBlock
    x:Name="txtStatus"
    Foreground="LimeGreen"
    FontWeight="Bold"/>
                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        CornerRadius="12"
                        Background="#1A233B"
                        Padding="15">

                    <StackPanel>

                        <TextBlock
                            Text="SECURITY LEVEL"
                            Foreground="#8E9AB9"/>

                        <TextBlock
                            Text="TIER 4 (RESTRICTED)"
                            Foreground="#FFA726"
                            FontWeight="Bold"/>
                    </StackPanel>

                </Border>

            </Grid>

            <!-- Cancel -->

            <Button Height="55"
                    Margin="40"
                    Content="Cancel Capture"
                    FontSize="18"
                Style="{DynamicResource NavigationButtonStyle}" Width="300"
                    BorderThickness="0"/>

        </StackPanel>

        <!-- Footer -->

        <Grid VerticalAlignment="Bottom"
              Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Text="ENCRYPTION : AES-256-GCM"
                Foreground="#5F6E95"/>

            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Right"
                       Text="LOG_STAMP : 14:58:26.448"
                       Foreground="#5F6E95"/>

        </Grid>

    </Grid>
</Window>
