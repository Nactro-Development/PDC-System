<Window x:Class="PDC_System.EmployeeAddData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
         xmlns:cal="clr-namespace:ModernCalendarLib;assembly=ModernCalendarLib"
         FontFamily="Poppins" WindowStartupLocation="CenterScreen" MinHeight="600" Width="1200" WindowStyle="None" AllowsTransparency="True" MinWidth="900" SnapsToDevicePixels="True"
        Foreground="{DynamicResource Forground}" Background="{DynamicResource ThemeBackground}" >

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
             CornerRadius="10"
                       
             ResizeBorderThickness="6"
             GlassFrameThickness="0"
             NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>


        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="6" >

            <Grid>


                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <Border CornerRadius="10" Margin="0"  x:Name="TitleBar" Grid.Row="0"
Background="{DynamicResource Background}" 
>
                    <DockPanel>
                        <!-- App Logo -->
                        <Image Source="/Assets/MainLogo.png"  Height="20" Width="20" Margin="8,0"/>
                        <!-- App Title -->
                        <TextBlock x:Name="PDCtitel" Text="Add Employee" Foreground="{DynamicResource Forground}"  VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Control Panel -->



                        <!-- Title bar buttons -->
                        <StackPanel Margin="0,0,5,0" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Minimize" Content="—" Width="25" Height="25" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}"/>
                            <Button x:Name="Maximize" Content="🗖" Width="25" Height="25" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                            <Button x:Name="Colose" Content="🗙" Width="25" Height="25" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                        </StackPanel>



                    </DockPanel>
                </Border>





                <Grid Grid.Row="1" >
                    <Border CornerRadius="10" Margin="10">
                      
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- LEFT COLUMN: Personal Details & Job Information -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">

                                    <!-- Personal Details -->
                                    <TextBlock Text="Personal Details:" Margin="10" FontSize="20" FontWeight="Bold"/>


                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Width="auto">
                                            <TextBlock Text="Full Name:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="EmployeeNameTextBox" Margin="10" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Width="auto">
                                            <TextBlock Text="Email:" Margin="10" FontSize="14"/>
                                            <TextBox  TextChanged="EmployeeEmailTextBox_TextChanged" x:Name="EmployeeEmailTextBox"  Style="{DynamicResource TextBoxStyle}" Width="auto" Margin="10" FontSize="16"/>
                                            <TextBlock x:Name="EmailErrorText" Margin="10,0" Foreground="Red" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Width="auto">
                                            <TextBlock Text="Birthday:" Margin="10" FontSize="14"/>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"  Margin="10" CornerRadius="5">
                                                <cal:CustomDatePicker x:Name="birthday"  Width="auto"  Height="auto" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Width="auto">
                                            <TextBlock Text="National ID:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="NatId" Margin="10" PreviewTextInput="NatId_PreviewTextInput" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="Primenry Phone Number:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="contact1" Margin="10" PreviewTextInput="PreviewTextInput" MaxLength="10" FontSize="16" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="Secondary Phone Number:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="contact2" Margin="10" PreviewTextInput="PreviewTextInput" MaxLength="10" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Width="auto">
                                            <TextBlock Text="Address Line 1:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="Address1" Margin="10" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="1" Width="auto">
                                            <TextBlock Text="Address Line 2:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="Address2" Margin="10" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="0">
                                            <TextBlock Text="City:" Margin="10" FontSize="14"/>
                                            <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" x:Name="city" IsEditable="True" DisplayMemberPath="Content" Margin="10" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Grid.Column="1">
                                            <TextBlock Text="Province:" Margin="10" FontSize="14"/>
                                            <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" x:Name="province" IsEditable="True" DisplayMemberPath="Content" Margin="10" FontSize="16">
                                                <ComboBoxItem Content="Western Province"/>
                                                <ComboBoxItem Content="Central Province"/>
                                                <ComboBoxItem Content="Southern Province"/>
                                                <ComboBoxItem Content="Northern Province"/>
                                                <ComboBoxItem Content="Eastern Province"/>
                                                <ComboBoxItem Content="North Western Province"/>
                                                <ComboBoxItem Content="North Central Province"/>
                                                <ComboBoxItem Content="Uva Province"/>
                                                <ComboBoxItem Content="Sabaragamuwa Province"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Job Information -->
                                    <TextBlock Text="Job Infomation" Margin="10,20,10,10" FontSize="20" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <Label Content="Job Role:" Foreground="{DynamicResource Forground}" Margin="10" TextBlock.FontSize="14"/>
                                            <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" x:Name="jrole" IsEditable="True" DisplayMemberPath="Content" Margin="10" FontSize="16">
                                                <ComboBoxItem Content="Graphic Designer" />
                                                <ComboBoxItem Content="Pre-Press Technician" />
                                                <ComboBoxItem Content="Typesetter" />
                                                <ComboBoxItem Content="Plate Maker" />
                                                <ComboBoxItem Content="Proofreader" />
                                                <ComboBoxItem Content="Press Operator" />
                                                <ComboBoxItem Content="Machine Assistant" />
                                                <ComboBoxItem Content="Print Technician" />
                                                <ComboBoxItem Content="Flexographic Printer" />
                                                <ComboBoxItem Content="Bindery Operator" />
                                                <ComboBoxItem Content="Laminator" />
                                                <ComboBoxItem Content="Die-Cutting Operator" />
                                                <ComboBoxItem Content="Embossing/Foiling Specialist" />
                                                <ComboBoxItem Content="Quality Control Inspector" />
                                                <ComboBoxItem Content="Production Manager" />
                                                <ComboBoxItem Content="Customer Service Representative" />
                                                <ComboBoxItem Content="Sales And Marketing Executive" />
                                                <ComboBoxItem Content="Estimator" />
                                                <ComboBoxItem Content="Logistics And Delivery Staff"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <Label Content="Depratment:" Foreground="{DynamicResource Forground}" Margin="10" TextBlock.FontSize="14"/>
                                            <ComboBox Style="{DynamicResource ComboBoxFlatStyle}" x:Name="Department" IsEditable="True" DisplayMemberPath="Content" Margin="10" FontSize="16">
                                                <ComboBoxItem Content="Offset Printing" />
                                                <ComboBoxItem Content="Digital Printing" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>

                                <!-- RIGHT COLUMN: Attendance Information & Salary Information -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">

                                    <!-- Attendance Information -->
                                    <TextBlock Text="Attendance Infomation" Margin="10" FontSize="20" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border BorderBrush="{DynamicResource BorderBrush}" 
        BorderThickness="1.5" 
        CornerRadius="10" 
        Padding="15"
        Background="{DynamicResource CardBackground}"
        Grid.Column="1" 
        Grid.Row="0">

                                            <StackPanel HorizontalAlignment="Center">

                                                <!-- Header with Icon -->
                                                <StackPanel Orientation="Horizontal" 
                     HorizontalAlignment="Center" 
                     Margin="0,0,0,3">
                                                    <TextBlock Text="🛡" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="15" 
                       FontWeight="SemiBold" 
                       Text="Register Finger Print"
                       VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Subtitle -->
                                                <TextBlock Text="Enroll biometric data for this user"
                   FontSize="11"
                   Foreground="#8E9AB9"
                   HorizontalAlignment="Center"
                   Margin="0,2,0,12"/>

                                                <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0" Orientation="Horizontal">

                                                    <!-- Finger 1 -->
                                                    <StackPanel Margin="5">
                                                        <Button Height="45" x:Name="Fingerorint1button"
                        Click="Finger1_Click" 
                        HorizontalAlignment="Center" 
                        Width="120" 
                        Style="{DynamicResource ActionButton}">

                                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                <Image RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" 
                               VerticalAlignment="Center" 
                               Width="18"
                               Source="/Assets/Scan.png"/>
                                                                <TextBlock Margin="8,0,0,0" 
                                   FontSize="12"
                                   VerticalAlignment="Center" 
                                   Text="Finger 1"/>
                                                            </StackPanel>
                                                        </Button>

                                                        <Border Background="Transparent"
                        CornerRadius="8"
                        Padding="0,3"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Stretch">
                                                            <TextBlock x:Name="txtFinger1"
                               Text="● Not Registered"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Forground}"
                               HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Finger 2 -->
                                                    <StackPanel Margin="5">
                                                        <Button Height="45" x:Name="Fingerorint2button"
                        Click="Finger2_Click" 
                        HorizontalAlignment="Center" 
                        Width="120" 
                        Style="{DynamicResource ActionButton}">

                                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                <Image RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" 
                               VerticalAlignment="Center" 
                               Width="18"
                               Source="/Assets/Scan.png"/>
                                                                <TextBlock Margin="8,0,0,0" 
                                   FontSize="12"
                                   VerticalAlignment="Center" 
                                   Text="Finger 2"/>
                                                            </StackPanel>
                                                        </Button>

                                                        <Border Background="Transparent"
                        CornerRadius="8"
                        Padding="0,3"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Stretch">
                                                            <TextBlock x:Name="txtFinger2"
                               Text="● Not Registered"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Forground}"
                               HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>

                                                </StackPanel>

                                            </StackPanel>

                                        </Border>


                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Employee ID/Attendance ID:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="EmployeeIDTextBox" Margin="10" SelectionTextBrush="White" PreviewTextInput="NumberOnly_PreviewTextInput" FontSize="16"/>

                                      
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Text="NoPay" Margin="10" FontSize="14"/>
                                                <TextBox  x:Name="NoPayTextBox" Style="{DynamicResource TextBoxStyle}" Margin="10" SelectionTextBrush="White" PreviewTextInput="NumberOnly_PreviewTextInput" FontSize="16"/>
                                            </StackPanel>
                                     
                                        </StackPanel>


                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Begin Time" Margin="10" FontSize="14"/>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"  Margin="10" CornerRadius="5">
                                                <cal:CustomDatePicker x:Name="begintimecal"  Width="auto"  Height="auto" />
                                            </Border>
                                        </StackPanel>

                                        

                                        <StackPanel Grid.Row="1" Grid.Column="1" >
                                            <TextBlock Text="End Time" Margin="10" FontSize="14"/>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"  Margin="10" CornerRadius="5">
                                                <cal:CustomDatePicker SelectedDateChanged="EndDatePicker_SelectedDateChanged" x:Name="endtimecal"  Width="auto"  Height="auto" />
                                            </Border>
                                        </StackPanel>




                                        <StackPanel Margin="5,20" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center">
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" CornerRadius="10">
                                                <StackPanel Margin="5">

                                                    <!-- Week Days -->
                                                    <TextBlock Text="Week Days" Margin="10" FontSize="14"/>

                                                    <StackPanel Margin="10" Orientation="Horizontal">

                                                        <TextBlock Text="Check In:" Margin="10" FontSize="14"/>

                                                        <ComboBox x:Name="CbCheckIn_Hour"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>

                                                        <TextBlock Text=":" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="6,0"/>

                                                        <ComboBox x:Name="CbCheckIn_Minute"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>


                                                        <TextBlock Text="Check Out:" Margin="20,10,10,10" FontSize="14"/>

                                                        <ComboBox x:Name="CbCheckOut_Hour"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>

                                                        <TextBlock Text=":" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="6,0"/>

                                                        <ComboBox x:Name="CbCheckOut_Minute"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>
                                                    </StackPanel>


                                                    <!-- Saturday -->
                                                    <TextBlock Text="Saturday" Margin="10" FontSize="14"/>

                                                    <StackPanel Margin="10" Orientation="Horizontal">

                                                        <TextBlock Text="Check In:" Margin="10" FontSize="14"/>

                                                        <ComboBox x:Name="CbSatCheckIn_Hour"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>

                                                        <TextBlock Text=":" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="6,0"/>

                                                        <ComboBox x:Name="CbSatCheckIn_Minute"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>


                                                        <TextBlock Text="Check Out:" Margin="20,10,10,10" FontSize="14"/>

                                                        <ComboBox x:Name="CbSatCheckOut_Hour"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>

                                                        <TextBlock Text=":" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="6,0"/>

                                                        <ComboBox x:Name="CbSatCheckOut_Minute"
                          Width="60" Height="40"
                          Style="{DynamicResource ComboBoxFlatStyle}"/>
                                                    </StackPanel>

                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2"  HorizontalAlignment="Center" >
                                            <TextBlock Text="Select Working Days:" Margin="10" FontSize="14"/>


                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Count Off Days" Margin="10" FontSize="14"/>
                                                <CheckBox x:Name="CountOffDays"/>
                                            </StackPanel>
                                            
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="MON" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Mon"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="THU" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Tue"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="WEN" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Wen"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="THE" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="The"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="FRI" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Fri"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="SAT" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Sat"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="SUN" Margin="10" FontSize="14"/>
                                                    <CheckBox x:Name="Sun"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Salary Information -->
                                    <TextBlock Text="Salary Infomation" Margin="10,20,10,10" FontSize="20" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Incentive:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" TextChanged="EmployeeIncentiveTextBox_TextChanged" x:Name="EmployeeIncentiveTextBox" Margin="10" PreviewTextInput="PreviewfloteTextInput" LostFocus="TextBox_LostFocus" FontSize="16"/>
                                            <TextBlock x:Name="EmployeeSalaryTextBox"  Margin="10" FontSize="14"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="Basic Salary:" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" TextChanged="EmployeeBasicTextBox_TextChanged" x:Name="EmployeeBasicSalaryTextBox" Margin="10" PreviewTextInput="PreviewfloteTextInput" LostFocus="TextBox_LostFocus" FontSize="16"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="OT (LKR):" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="EmployeeOTTextBox" Margin="10" PreviewTextInput="PreviewfloteTextInput" LostFocus="TextBox_LostFocus" FontSize="16" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="DOT (LKR):" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="EmployeeDOTTextBox" Margin="10" PreviewTextInput="PreviewfloteTextInput" LostFocus="TextBox_LostFocus" FontSize="16"/>
                                            
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="Absent(LKR):" Margin="10" FontSize="14"/>
                                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="EmployeeAbsentTextBox" Margin="10" PreviewTextInput="PreviewfloteTextInput" LostFocus="TextBox_LostFocus" FontSize="16"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="Absent(LKR):" Margin="10" FontSize="14"/>
                                            <Button Style="{DynamicResource ActionButton}" Content="Autofill" Click="Autofill_Salary" />
                                        </StackPanel>

                                        <!-- Buttons at Bottom -->
                                        <StackPanel Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2" Margin="20" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="Save" Width="100" Height="30" Click="SaveButton_Click" Style="{DynamicResource ActionButton}" />
                                            <Button Content="Cancel" Width="100" Height="30" Margin="10,0,0,0" Click="CancelButton_Click" Style="{DynamicResource NavigationButtonStyle}" />
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>


                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>


            </Grid>
        </Border>


    </Grid>
    
    
    
    
    

</Window>