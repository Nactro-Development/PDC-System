<UserControl x:Class="PDC_System.HomeUIWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDC_System"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             MinHeight="550" MinWidth="675"
             FontFamily="{StaticResource CustomFont}">

    <UserControl.Resources>
        <Style TargetType="Image">
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Panels -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,20,0,20">
                <UniformGrid Grid.Row="0"
             Grid.ColumnSpan="3"
             Columns="3"
             Margin="0,10,0,10">

                    <!-- TOTAL JOBS CARD -->
                    <Border Background="{DynamicResource Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
            CornerRadius="20"
            Margin="0,5,5,5"
            Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Width="50"
                    Height="50"
                    Background="#FFEB6E4E"
                    CornerRadius="25"
                    VerticalAlignment="Center">

                                <Image Source="/Assets/Asset_25.png"
                       Width="24"
                       Height="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>

                            <!-- Text -->
                            <StackPanel Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center">

                                <TextBlock Text="TOTAL JOBS"
                           Foreground="#9CA3AF"
                           FontSize="13"/>

                                <TextBlock x:Name="Total_Jobs"
                           Text="0"
                           Foreground="{DynamicResource Forground}"
                           FontSize="30"
                           FontWeight="Bold"/>

                            </StackPanel>

                        </Grid>

                    </Border>


                    <!-- PRESENT TODAY CARD -->
                    <Border Background="{DynamicResource Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
            CornerRadius="20"
            Margin="5"
            Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="50"
                    Height="50"
                    Background="#16a34a"
                    CornerRadius="25">

                                <Image Source="/Assets/Asset_24.png"
                       Width="24"
                       Height="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                        Margin="15,0,0,0">

                                <TextBlock Text="PRESENT TODAY"
                           Foreground="#9CA3AF"
                           FontSize="13"/>

                                <TextBlock x:Name="Present_Employee"
                           Text="0"
                            Foreground="{DynamicResource Forground}"
                           FontSize="30"
                           FontWeight="Bold"/>

                            </StackPanel>

                        </Grid>

                    </Border>


                    <!-- TOTAL CUSTOMERS CARD -->
                    <Border Background="{DynamicResource Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
            CornerRadius="20"
            Margin="5,5,0,5"
            Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="50"
                    Height="50"
                    Background="#FFEB194E"
                    CornerRadius="25">

                                <Image Source="/Assets/Asset_37.png"
                       Width="24"
                       Height="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                        Margin="15,0,0,0">

                                <TextBlock Text="TOTAL CUSTOMERS"
                           Foreground="#9CA3AF"
                           FontSize="13"/>

                                <TextBlock x:Name="Total_Customers"
                           Text="0"
                           Foreground="{DynamicResource Forground}"
                           FontSize="30"
                           FontWeight="Bold"/>

                            </StackPanel>

                        </Grid>

                    </Border>

                </UniformGrid>
            </StackPanel>

            <!-- Left Bar Chart -->
            <Border x:Name="Panel_2" Grid.Column="0" Grid.Row="1" BorderThickness="3" Background="{DynamicResource Background}" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="30" Margin="5,20,5,20" HorizontalAlignment="Stretch">
                <StackPanel VerticalAlignment="Bottom" Margin="20" HorizontalAlignment="Stretch">
                    <TextBlock x:Name="countjobname" Text="Monthly Jobs" Foreground="{DynamicResource Forground}" FontSize="20"/>
                    <TextBlock x:Name="Countofjob" Text="10" Foreground="{DynamicResource Forground}" FontSize="30"/>

                    <Grid Margin="20">
                        <ItemsControl Name="BarChart" HorizontalAlignment="Stretch">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="10" VerticalAlignment="Bottom">
                                        <Rectangle Width="50" Height="{Binding Value}" Fill="#FF0660FE" RadiusX="5" RadiusY="5" />
                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource Barcolor}" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </Border>




            <!-- Upcoming Birthdays -->
            <Grid Grid.Column="1" HorizontalAlignment="Stretch" Grid.Row="1" Grid.ColumnSpan="2" Margin="5,20,5,20">

                <Border  HorizontalAlignment="Stretch"
            BorderThickness="3" 
                    Background="{DynamicResource Background}"
            BorderBrush="#FF0660FE"  
            CornerRadius="30"
            Padding="10">


                    <Grid HorizontalAlignment="Stretch" Margin="15">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Up Coming Birthdays"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

                        <ListBox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch"  Height="300" ItemsSource="{Binding UpcomingBirthdays}"
             Background="Transparent"
             BorderThickness="0">

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,5"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>

                                    <Grid Margin="0,8">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Width="48"
                            Height="48"
                            CornerRadius="24"
                            Background="#2563EB">

                                            <TextBlock Text="👤"
                                   FontSize="22"
                                                       Foreground="{DynamicResource ForgroudColor}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1"
                                Margin="10,0">

                                            <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="15"/>

                                            <TextBlock Text="{Binding Designation}"
                                   Foreground="#B8C0D4"
                                   FontSize="12"/>
                                        </StackPanel>


                                        <Grid   HorizontalAlignment="Right"  Grid.Column="2" >
                                            <Border  HorizontalAlignment="Right"   
Padding="16,8"
CornerRadius="12">

                                                <Border.Style>
                                                    <Style TargetType="Border">

                                                        <Setter Property="Background"
            Value="#2563EB"/>

                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding DaysLeft}"
                     Value="0">
                                                                <Setter Property="Background"
                    Value="#EC4899"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding DaysLeft}"
                     Value="1">
                                                                <Setter Property="Background"
                    Value="#10B981"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding DaysLeft}"
                     Value="2">
                                                                <Setter Property="Background"
                    Value="#F59E0B"/>
                                                            </DataTrigger>

                                                        </Style.Triggers>

                                                    </Style>
                                                </Border.Style>

                                                <TextBlock VerticalAlignment="Center" Text="{Binding BirthdayDate}"
       Foreground="White"
       FontWeight="Bold"
       FontSize="14"/>

                                            </Border>


                                        </Grid>
                                        <!-- Date Badge -->
                                 
                                    </Grid>

                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                        <Image Grid.Column="1" Grid.Row="1" Height="300" Source="/Assets/birthday.png" />

                    </Grid>
                    
               

                    
                    





                </Border>

            </Grid>

            <Border Grid.Row="2" Grid.ColumnSpan="3" Grid.Column="0"
Background="{DynamicResource Background}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="3"
CornerRadius="14"
Padding="16"
Margin="5">

                <StackPanel>
                    <TextBlock Text="Attendance Overview (Last 7 Days)"
           FontSize="16"
                           Foreground="{DynamicResource Forground}"
           FontWeight="SemiBold"
           Margin="0,0,0,12"/>

                    <lvc:CartesianChart Series="{Binding AttendanceSeries}"
                    LegendLocation="None"
                    Height="220"
                    Background="Transparent">

                        <!-- X AXIS -->
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding Labels}"
                  Foreground="#8A8F98">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1"
                                           IsEnabled="False"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>

                        <!-- Y AXIS -->
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis ShowLabels="True" MinValue="0">
                                <lvc:Axis.Separator>
                                    <lvc:Separator IsEnabled="False"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>

                    </lvc:CartesianChart>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

</UserControl>
