<Window x:Class="PDC_System.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:svg="http://dotnetprojects.github.io/SVGImage"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDC_System"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        Title="PDC System"
        Background="Transparent"
        WindowStyle="None" 
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowState="Normal"
        MinWidth="1600"
        MinHeight="900"
        Width="1450"
        Icon="/Assets/Main.ico"
        Height="900">

    <!-- WindowChrome for custom window border and rounded corners -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                    CornerRadius="10"
                    ResizeBorderThickness="6"
                    GlassFrameThickness="0"
                    NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Window-wide styles for Buttons -->
    <Window.Resources>
        <Style TargetType="Button">
            <!-- Text color of button -->
            <Setter Property="Foreground" Value="White"/>
            <!-- Default button width -->
            <Setter Property="Width" Value="100"/>
            <!-- Remove default border -->
            <Setter Property="BorderThickness" Value="0"/>
            <!-- Padding inside button -->
            <Setter Property="Padding" Value="12,8"/>
            <!-- Font weight -->
            <Setter Property="FontWeight" Value="Medium"/>
            <!-- Change cursor on hover -->
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Custom button background with rounded corners -->
                        <Border Background="{TemplateBinding Background}" 
                             CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main border around the Home UI -->
    <Border CornerRadius="6" BorderThickness="2" BorderBrush="{DynamicResource BorderBrush}" x:Name="HomeUi" Background="#0c0c0c" >

        <Grid x:Name="RootGrid" >
            <!-- Main grid for layout -->

            <Grid  Height="auto">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <!-- Sidebar column -->
                    <ColumnDefinition/>
                    <!-- Main content column -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <!-- Title bar row -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>

                </Grid.RowDefinitions>

                <!-- Custom Title Bar -->
                <Border Margin="5" x:Name="TitleBar" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource TitleBarBackground}" 
                >
                    <DockPanel>
                        <!-- App Logo -->
                        <Image Source="/Assets/MainLogo.png"  Height="20" Width="20" Margin="8,0"/>
                        <!-- App Title -->
                        <TextBlock x:Name="PDCtitel" Text="PDC System" Foreground="{DynamicResource Forground}"  VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Control Panel -->

                       


                        <!-- Title bar buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">



                            <StackPanel Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True" HorizontalAlignment="Right">





                              
                               



                            </StackPanel>

                            <StackPanel shell:WindowChrome.IsHitTestVisibleInChrome="True" >

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" >

                                    <Grid>

                                        <!-- User Button -->
                                        <Button x:Name="UserButton"
            Width="40"
            Height="40"
            Background="Transparent"
            BorderThickness="0"
            Click="UserButton_Click">

                                            <Border Background="#0660FE"
                CornerRadius="20"
                Width="30"
                Height="30">

                                                <TextBlock Text="A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="White"
                                                           x:Name="UserNameTextBox"
                       FontWeight="SemiBold"
                       FontSize="15"/>

                                            </Border>
                                        </Button>

                                        <!-- Popup -->
                                        <Popup x:Name="UserPopup"
       PlacementTarget="{Binding ElementName=UserButton}"
       Placement="Bottom"
                                               
       StaysOpen="False"
       AllowsTransparency="True">

                                            <Border Background="{DynamicResource ThemeBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1.5"
            CornerRadius="10"
            Padding="10"
            MinWidth="220">

                                                <StackPanel>

                                                    <!-- User Info -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                                                        <Border Width="40"
                        Height="40"
                        CornerRadius="20"
                        Background="#0660FE">

                                                            <TextBlock Text="A"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                                                        </Border>

                                                        <StackPanel Margin="10,0,0,0"
                            VerticalAlignment="Center">

                                                            <TextBlock x:Name="PopupUserName"
                               Text="Kavindu Kaushalya"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{DynamicResource ForgroudColor}"/>

                                                            <TextBlock x:Name="Adminitaterusername" Text="Administrator"
                               FontSize="11"
                               Foreground="Gray"/>

                                                        </StackPanel>

                                                    </StackPanel>

                                                    <Separator Margin="0,0,0,8"/>

                                                    <!-- Menu -->

                                                    <Button Content="⚙ Settings"
                    Style="{DynamicResource NavigationButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="Setting_Click"/>

                                                    <Button Content="🗄 Backup"
                    Style="{DynamicResource NavigationButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="Backup_Click"/>

                                                    <Button Content="ℹ About"
                    Style="{DynamicResource NavigationButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="AboutButton_Click"/>

                                                    <Separator Margin="0,8"/>

                                                    <Button Content="⏻ Log Out"
                    Style="{DynamicResource NavigationButtonStyle}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="Log_out"/>

                                                </StackPanel>

                                            </Border>

                                        </Popup>

                                    </Grid>



                                </StackPanel>


                            </StackPanel>


                            <Button x:Name="Minimize" Content="—" Width="25" Height="25" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Style="{DynamicResource NavigationButtonStyle}" />
                            <Button x:Name="Maximize" Content="🗖" Width="25" Height="25" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Style="{DynamicResource NavigationButtonStyle}"  />
                            <Button x:Name="Colose" Content="🗙" Width="25" Height="25" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Style="{DynamicResource NavigationButtonStyle}" />
                        </StackPanel>



                      




                    </DockPanel>
                </Border>

                <Grid  Grid.Row="1" Height="auto">
                    <Border Background="{DynamicResource Background}" CornerRadius="20" Margin="10,0,10,10" >





                        <Grid>



                            <StackPanel VerticalAlignment="Top" Margin="10" Grid.Row="0" MinHeight="500">

                                <!-- Home -->
                                <RadioButton x:Name="Dashbord" IsChecked="True" Click="OpenView8_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image Source="/Assets/Asset_29.png" Width="16" Margin="0,0,0,3" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Home" FontFamily="Poppins" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Text="Show Full Overview of System." FontFamily="Poppins" FontWeight="Regular" 
               FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="Email"  Click="OpenView15_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image Source="/Assets/Email.png" Width="16" Margin="0,0,0,3" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Emails" FontFamily="Poppins" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Text="Show Emails of System." FontFamily="Poppins" FontWeight="Regular" 
               FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>


                                <TextBlock Text="Printing" FontSize="14" FontWeight="Bold" Margin="10,20,0,10" Foreground="#FF0660FE"/> 

                                <!-- Order Check -->
                                <RadioButton x:Name="OderCheck" Click="OpenView9_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_32.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Order Check" FontFamily="Poppins" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="Mark and monitor daily order." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Job Card -->
                                <RadioButton x:Name="Jobcard" Click="OpenView2_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_23.png" Width="15" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Job Card" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Mark and monitor daily Jobs." FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Customer -->
                                <RadioButton x:Name="Customer" Click="OpenView1_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_33.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Customer" FontWeight="SemiBold"  FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Customers and details." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Outsourcing -->
                                <RadioButton x:Name="Outsourcing" Click="OpenView11_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_46.png" Width="18" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Outsourcing" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Outsourcing and details." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <TextBlock Text="Finance And Management" FontSize="14" FontWeight="Bold" Margin="10,20,0,10" Foreground="#FF0660FE"/>

                                <!-- Quotation -->
                                <RadioButton x:Name="Quotation" Click="OpenView3_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_34.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Finance" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Create Quotation and Invoice." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Employee -->
                                <RadioButton x:Name="Employee" Click="OpenView4_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image Source="/Assets/Asset_27.png" Width="18" Margin="0,0,0,3" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Employee" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Add Employee and Details." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>


                                <!-- Payroll -->
                                <RadioButton x:Name="Payroll" Click="OpenView12_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Payroll.png" Width="18" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Payroll" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Manage payroll and holidays." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Paysheet -->
                                <RadioButton x:Name="Paysheet" Click="OpenView13_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_36.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Paysheet" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Monitor monthly paysheets." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>



                                <TextBlock Text="Attendance" FontSize="14" FontWeight="Bold" Margin="10,20,0,10" Foreground="#FF0660FE"/>

                                <!-- Attendance -->
                                <RadioButton x:Name="Attendance" Click="OpenView5_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_35.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="Attendance Details" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Monitor daily attendance and Holidays." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>



                                <!-- User Manager -->

                                <RadioButton x:Name="UserManagerTAB" Click="OpenView14_Click" Style="{StaticResource SelectableRadioButtonStyle}" 
                 Margin="3" Width="250" Height="45">
                                    <StackPanel Orientation="Horizontal" Width="200" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" Source="/Assets/Asset_27.png" Width="16" Margin="0,0,0,3"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="User Manager" FontWeight="SemiBold" FontFamily="Poppins" FontSize="13"/>
                                            <TextBlock Text="Monitor monthly paysheets." FontSize="9" FontFamily="Poppins" FontWeight="Regular"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>


                             

                            </StackPanel>




                         








                        </Grid>
                        
                        
                        
                        
                    </Border>
                </Grid>

                <!-- Sidebar / Navigation Menu -->
              
               
                 
      

                <!-- Right Top Section for Google Account Info and Settings -->


                <!-- Main Content Display Area -->
                <Grid Grid.Row="1" Grid.Column="1">
                    <Border  Margin="0,0,5,0" CornerRadius="15" BorderThickness="1" BorderBrush="Transparent" Grid.Row="1" Grid.Column="1" Background="{DynamicResource ContBackground}">
                        <Grid   >

                            <Grid.Background>
                                <DrawingBrush TileMode="Tile"
           Viewport="0,0,30,30"
           ViewportUnits="Absolute"
           Stretch="None">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="{DynamicResource ThemeBackgroundDotsColor}">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry
                 Center="3,3"
                 RadiusX="1"
                 RadiusY="1"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Grid.Background>

                            <Border CornerRadius="20">
                                <ContentControl  Margin="20,20,0,8" x:Name="MainContent"   Background="Transparent"  />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>


                <Grid Grid.Row="3" Grid.ColumnSpan="3" >
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" >
                        <Image RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" HorizontalAlignment="Left" VerticalAlignment="Center" Source="/Assets/Backup.png" Width="15"/>
                        
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" Text="Fingerprint Sync" FontSize="10" Foreground="{DynamicResource Forground}" FontWeight="Regular" />

                        <TextBlock HorizontalAlignment="Center" x:Name="check_status" VerticalAlignment="Center" Margin="10,0,0,0" Text="Last Check: 2026-06-26 4:06pm" Foreground="Gray" />

                    </StackPanel>

                </Grid>

            </Grid>
        </Grid>

    </Border>
</Window>
