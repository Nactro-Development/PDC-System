<UserControl x:Class="PDC_System.Customers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PDC_System"
             mc:Ignorable="d" 
             FontFamily="{StaticResource CustomFont}"
             MinWidth="1004" MinHeight="660">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ROW 0: TITLE -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Customers" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       Foreground="{DynamicResource Forground}"                        
                       TextAlignment="Left"
                       Margin="0,0,0,5" />

            <TextBlock Grid.Row="1"
                       Text="• View and manage all registered customers and companies." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="2"
                       Text="• Add new customers using the '+ Add Customer' button." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="3"
                       Text="• Delete existing customers from the action column." 
                       FontSize="12" 
                       FontWeight="Normal" 
                       Foreground="#FF7D7D7D"
                       TextAlignment="Left"
                       Padding="0,0,0,18"/>
        </Grid>


        <!-- ROW 1: STATS CARDS -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Customers -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Background}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="2"
                    CornerRadius="15"
                    Padding="20"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TOTAL CUSTOMERS"
                               Foreground="#9CA3AF"
                               FontSize="13"/>

                    <TextBlock Grid.Row="1"
                               x:Name="TotalCustomersTxt"
                               Text="0"
                               Foreground="#35d499"
                               FontSize="28"
                               FontWeight="Bold"/>
                </Grid>
            </Border>

            <!-- Total Companies -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="2"
                    CornerRadius="15"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TOTAL COMPANIES"
                               Foreground="#9CA3AF"
                               FontSize="13"/>

                    <TextBlock Grid.Row="1"
                               x:Name="TotalCompaniesTxt"
                               Text="0"
                               Foreground="#5b9ced"
                               FontSize="28"
                               FontWeight="Bold"/>
                </Grid>
            </Border>
        </Grid>


        <!-- ROW 2: ADD BUTTON -->
        <Grid Grid.Row="2" Margin="10,0,10,0">
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource ActionButton}" 
                    Content="+ Add Customer" 
                    Click="AddCustomer_Click" 
                    Width="250"
                    Margin="30"/>
        </Grid>


        <!-- ROW 3: DATAGRID -->
        <DataGrid Grid.Row="3"
                  x:Name="CustomerDataGrid"
                  Margin="10"
                  BorderBrush="{x:Null}"
                  HeadersVisibility="Column"
                  Background="Transparent"
                  RowBackground="White"
                  AlternatingRowBackground="#f0f0f0"
                  SnapsToDevicePixels="True"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="False"
                  CellStyle="{StaticResource DataGridCellStyle}"
                  Style="{StaticResource DataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  RowStyle="{StaticResource DataGridRowStyle}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"  ElementStyle="{StaticResource DataGridColumnsStyle}"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="2*" ElementStyle="{StaticResource DataGridColumnsStyle}"/>
                <DataGridTextColumn Header="Email"   Binding="{Binding Email}"   Width="2*" ElementStyle="{StaticResource DataGridColumnsStyle}"/>
                <DataGridTextColumn Header="Type"    Binding="{Binding Type}"    Width="2*" ElementStyle="{StaticResource DataGridColumnsStyle}"/>

                <DataGridTemplateColumn Header="Action" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="Edit"
                                        Click="EditCustomer_Click"
                                        Style="{DynamicResource EditActionButton}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="Delete"
                                        Click="DeleteCustomer_Click"
                                        Style="{DynamicResource DeleteActionButton}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
